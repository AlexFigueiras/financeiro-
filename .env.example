# === Banco de Dados (Supabase / PostgreSQL) ===
# Use a connection string do Supabase (Settings > Database > Connection string)
# ou de qualquer PostgreSQL >= 13.
DATABASE_URL=postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:5432/postgres
# "true" para Supabase/conexões TLS; "false" para Postgres local sem SSL.
DATABASE_SSL=true

# === Mercado Pago (Módulo A) ===
# Access Token de PRODUÇÃO (começa com APP_USR-...)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Google Gemini (Módulo C - OCR de cupons) ===
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-flash

# === Servidor ===
PORT=3000

# Intervalo (minutos) do cron de sincronização Mercado Pago + reconciliação.
SYNC_INTERVAL_MINUTES=30
