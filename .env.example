# === Banco de Dados (Supabase / PostgreSQL) ===
# Use a connection string do "Transaction pooler" do Supabase (Settings > Database >
# Connection string, porta 6543) ou de qualquer PostgreSQL >= 13.
DATABASE_URL=postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:6543/postgres
# "true" para Supabase/conexões TLS; "false" para Postgres local sem SSL.
DATABASE_SSL=true
# Valida o certificado do servidor por padrão (recomendado). Só desligue em dev local
# contra um Postgres sem CA confiável — nunca em produção.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# CA do Supabase (Settings > Database > SSL Configuration > baixar certificado).
# Cole aqui o conteúdo do .crt (com as quebras de linha como \n) se DATABASE_SSL_REJECT_UNAUTHORIZED=true.
DATABASE_CA_CERT=

# === Google Gemini (OCR de cupons/extratos) ===
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-flash

# === Servidor ===
PORT=3000
LOG_LEVEL=info

# Intervalo (minutos) do cron de reconciliação em dev local (AUTH_MODE=off).
SYNC_INTERVAL_MINUTES=30

# === Autenticação / multi-tenant (Supabase Auth) ===
# "supabase" (padrão, produção) exige login; "off" é single-user local, sem auth — NUNCA em produção.
AUTH_MODE=supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=
# Settings > API > JWT Secret (usado para validar o token no backend, HS256).
SUPABASE_JWT_SECRET=
# Tenant fixo usado apenas quando AUTH_MODE=off (dev local).
DEV_TENANT_ID=00000000-0000-4000-8000-000000000000
