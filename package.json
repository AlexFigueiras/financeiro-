{
  "name": "financeiro",
  "version": "1.0.0",
  "description": "SaaS de Controle Financeiro Pessoal e Reconciliação Bancária Automatizada (multi-tenant)",
  "main": "dist/src/index.js",
  "scripts": {
    "prepare": "lefthook install",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "db:migrate": "tsx src/infra/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify-rules": "node scripts/verify-rules.js",
    "generate": "node scripts/generate.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "lefthook": "^2.1.9",
    "supertest": "^7.2.2",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
